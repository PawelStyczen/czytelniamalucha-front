---
import type { CollectionEntry } from "astro:content";

interface Props {
  post: CollectionEntry<"blog">;
  headingTag?: "h2" | "h3";
  variant?: "default" | "compact";
  ctaLabel?: string;
}

const {
  post,
  headingTag = "h3",
  variant = "default",
  ctaLabel = "Czytaj artykuł →",
} = Astro.props;

const HeadingTag = headingTag;
---

<a
  href={`/blog/${post.slug}/`}
  class="blog-post-card paper-shadow"
  data-variant={variant}
>
  <div class="blog-post-card__surface paper-texture">
    <div class="blog-post-card__media">
      <img
        src={post.data.image}
        alt={post.data.title}
        class="blog-post-card__image"
        loading="lazy"
      />
    </div>

    <div class="blog-post-card__meta">
      {post.data.pubDate.toLocaleDateString("pl-PL")}
    </div>

    <HeadingTag class="blog-post-card__title">{post.data.title}</HeadingTag>

    <p class="blog-post-card__desc">{post.data.description}</p>

    <span class="blog-post-card__cta">{ctaLabel}</span>
  </div>
</a>

<style>
  .blog-post-card {
    display: flex;
    flex-direction: column;
    min-height: 100%;
    text-decoration: none;
    color: inherit;
  }

  .blog-post-card__surface {
    display: flex;
    flex-direction: column;
    min-height: 100%;
    overflow: hidden;
    background: rgba(255, 250, 244, 0.88);
    border: 1px solid rgba(58, 58, 58, 0.08);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.04);
    transition:
      box-shadow 0.18s ease,
      border-color 0.18s ease;
  }

  .blog-post-card:hover .blog-post-card__surface {
    box-shadow: 0 18px 40px rgba(0, 0, 0, 0.08);
    border-color: rgba(107, 143, 113, 0.22);
  }

  .blog-post-card__media {
    aspect-ratio: 16 / 10;
    background: rgba(107, 143, 113, 0.08);
  }

  .blog-post-card__image {
    display: block;
    width: 100%;
    height: 300px;
    object-fit: cover;
  }

  .blog-post-card__meta {
    font-size: 0.9rem;
    color: rgba(58, 58, 58, 0.55);
    margin: 1.2rem 1.4rem 0.75rem;
  }

  .blog-post-card__title {
    margin: 0 1.4rem 0.75rem;
    font-size: 1.25rem;
    line-height: 1.3;
  }

  .blog-post-card__desc {
    margin: 0 1.4rem;
    color: rgba(58, 58, 58, 0.78);
    line-height: 1.7;
    flex-grow: 1;
  }

  .blog-post-card__cta {
    margin: 1.2rem 1.4rem 1.4rem;
    font-weight: 700;
    color: #6b8f71;
  }

  .blog-post-card[data-variant="compact"] {
  }

  .blog-post-card[data-variant="compact"] .blog-post-card__surface {
    box-shadow: 0 10px 28px rgba(0, 0, 0, 0.04);
  }

  .blog-post-card[data-variant="compact"] .blog-post-card__title {
    font-size: 1.18rem;
  }

  .blog-post-card[data-variant="compact"] .blog-post-card__cta {
    margin-top: 1rem;
  }

  @media (max-width: 640px) {
    .blog-post-card,
    .blog-post-card[data-variant="compact"] {
      min-height: auto;
    }
  }
</style>
