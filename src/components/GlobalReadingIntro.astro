---
const steps = [
  {
    number: "01",
    image: "/img/why-global/01-why-global-1.png",
    imageAlt: "Karty do nauki pierwszych słów",
    title: "Pokazujesz całe słowo",
    text: "Dziecko widzi wyraz jako całość, bez rozbijania go od razu na litery i sylaby.",
  },
  {
    number: "02",
    image: "/img/why-global/02-why-global.png",
    imageAlt: "Rodzic pracuje z dzieckiem krótko i regularnie",
    title: "Powtarzacie krótko i regularnie",
    text: "Najlepiej działają spokojne, krótkie sesje, które budują oswojenie z czytaniem bez presji.",
  },
  {
    number: "03",
    image: "/img/why-global/03-why-global.png",
    imageAlt: "Materiały do czytania globalnego używane w codziennej zabawie",
    title: "Łączycie słowo z codziennością",
    text: "Wyrazy pojawiają się w zabawie, ruchu i rozmowie, więc dziecko szybciej nadaje im znaczenie.",
  },
];
---

<section class="global-reading section" id="globalne-czytanie">
  <div class="container">
    <div class="global-reading__intro">
      <h2 class="h2 global-reading__title">Co to jest globalne czytanie?</h2>
      <p class="global-reading__lead">
        To metoda, w której dziecko najpierw poznaje całe wyrazy, a dopiero z
        czasem zaczyna rozpoznawać ich budowę. Dzięki temu nauka może być
        spokojna, intuicyjna i bliższa codziennemu doświadczeniu.
      </p>
    </div>

    <div class="global-reading__steps">
      {
        steps.map((step) => (
          <article class="global-reading__card card">
            <div class="global-reading__number">{step.number}</div>
            <div class="global-reading__card-image-wrap">
              <img
                src={step.image}
                alt={step.imageAlt}
                class="global-reading__card-image"
                loading="lazy"
              />
            </div>

            <h3 class="global-reading__card-title">{step.title}</h3>
            <p class="global-reading__card-text">{step.text}</p>
          </article>
        ))
      }
    </div>

    <figure class="global-reading__figure">
      <figcaption class="global-reading__caption">
        Czytanie globalne nie polega na pośpiechu. Chodzi o oswajanie dziecka z
        językiem poprzez proste słowa, powtarzalność i atmosferę zabawy.
      </figcaption>
    </figure>
  </div>
</section>

<style>
  .global-reading {
    position: relative;
  }

  .global-reading__intro {
    max-width: 760px;
    margin-bottom: 1.75rem;
  }

  .global-reading__title {
    margin-top: 0.35rem;
    margin-bottom: 0.9rem;
    font-size: clamp(1.8rem, 3vw, 2.6rem);
  }

  .global-reading__lead {
    margin: 0;
    font-family: var(--font-serif);
    font-size: 1.05rem;
    line-height: 1.8;
    color: rgba(58, 58, 58, 0.82);
    max-width: 62ch;
  }

  .global-reading__steps {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.25rem;
    margin-bottom: 2rem;
    align-items: stretch;
  }

  .global-reading__card {
    position: relative;
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: 1.75rem 1.5rem 1.5rem;
    background:
      linear-gradient(
        180deg,
        rgba(255, 253, 248, 0.98),
        rgba(249, 244, 235, 0.96)
      ),
      repeating-linear-gradient(
        180deg,
        rgba(107, 143, 113, 0.035) 0,
        rgba(107, 143, 113, 0.035) 1px,
        transparent 1px,
        transparent 44px
      );
    border: 1px solid rgba(58, 58, 58, 0.12);
    box-shadow: 0 16px 28px rgba(0, 0, 0, 0.08);
    overflow: hidden;
  }

  .global-reading__card:nth-child(1) {
    transform: rotate(-1deg);
  }

  .global-reading__card:nth-child(2) {
    transform: rotate(0.8deg);
  }

  .global-reading__card:nth-child(3) {
    transform: rotate(-0.7deg);
  }

  .global-reading__card-image-wrap {
    overflow: hidden;
    width: min(100%, 300px);
    aspect-ratio: 1 / 1;
    margin: 0 auto 1rem;
    border-radius: 50%;
    background:;
  }

  .global-reading__card-image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .global-reading__number {
    display: flex;
    align-items: center;
    justify-content: center;
    width: fit-content;
    min-width: 3.6rem;
    padding: 0.35rem 0.75rem;
    border-radius: 999px;
    margin: 0 auto 0.8rem;
    background: var(--paper);
    color: var(--wood);
    font-size: 3rem;
    font-weight: 800;
    letter-spacing: 0.08em;
  }

  .global-reading__card-title {
    margin: 0 0 0.7rem;
    font-size: 1.15rem;
    line-height: 1.3;
    text-align: center;
  }

  .global-reading__card-text {
    margin: 0;
    font-family: var(--font-serif);
    line-height: 1.75;
    color: rgba(58, 58, 58, 0.8);
    text-align: center;
  }

  .global-reading__figure {
    margin: 0;
  }

  .global-reading__image-shell {
    overflow: hidden;
    border-radius: 30px;
    border: 1px solid rgba(58, 58, 58, 0.08);

    background: #fff;
  }

  .global-reading__image {
    display: block;
    width: 100%;
    max-height: 520px;
    object-fit: cover;
  }

  .global-reading__caption {
    margin-top: 1rem;
    font-family: var(--font-serif);
    font-size: 1rem;
    line-height: 1.8;
    color: rgba(58, 58, 58, 0.76);
    max-width: 70ch;
  }

  @media (max-width: 980px) {
    .global-reading__steps {
      grid-template-columns: 1fr;
    }

    .global-reading__card:nth-child(1),
    .global-reading__card:nth-child(2),
    .global-reading__card:nth-child(3) {
      transform: none;
    }
  }

  @media (max-width: 640px) {
    .global-reading__card {
      padding: 1.25rem;
    }

    .global-reading__card-image-wrap {
      width: min(100%, 220px);
    }

    .global-reading__image-shell {
      border-radius: 24px;
    }

    .global-reading__caption {
      font-size: 0.98rem;
    }
  }
</style>
